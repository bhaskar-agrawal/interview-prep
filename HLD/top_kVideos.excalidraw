      "versionNonce": 29748840,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772859402399,
      "link": null,
      "locked": false,
      "text": "2. support tumbling videos of 1{hour, day, month} and all time (upto a max of 1k results):\n   Notes;\n    1. add the timestamp also in the postgres, it will be on hourly basis\n    2. multiple writes for each video, in a single hour. As each write is coming\n    from each view.\n    3. This sql query: \n         SELECT \"videoId\", SUM(\"views\") as \"views\", \n        FROM VideoViews \n        WHERE \"timestamp\" >= {windowStart} AND \"timestamp\" <= {windowEnd}\n        GROUP BY \"videoId\"\n        ORDER BY SUM(\"views\") DESC LIMIT {k};",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. support tumbling videos of 1{hour, day, month} and all time (upto a max of 1k results):\n   Notes;\n    1. add the timestamp also in the postgres, it will be on hourly basis\n    2. multiple writes for each video, in a single hour. As each write is coming\n    from each view.\n    3. This sql query: \n         SELECT \"videoId\", SUM(\"views\") as \"views\", \n        FROM VideoViews \n        WHERE \"timestamp\" >= {windowStart} AND \"timestamp\" <= {windowEnd}\n        GROUP BY \"videoId\"\n        ORDER BY SUM(\"views\") DESC LIMIT {k};",
      "autoResize": true,
      "lineHeight": 1.25
    },
