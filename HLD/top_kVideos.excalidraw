    {
      "id": "AK4f98s1tO5bNVwVV_MPA",
      "type": "text",
      "x": 248.40261271806986,
      "y": -8828.234349798508,
      "width": 351.1998291015625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "b1K",
      "roundness": null,
      "seed": 533361123,
      "version": 150,
      "versionNonce": 1510919683,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763993102032,
      "link": null,
      "locked": false,
      "text": "the sample sql query here:\nSELECT \"videoId\", \"views\"\nFROM VideoViews\nORDER BY \"views\" DESC LIMIT k; ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "the sample sql query here:\nSELECT \"videoId\", \"views\"\nFROM VideoViews\nORDER BY \"views\" DESC LIMIT k; ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "dUIiifEkg93ypGdA9t8Fj",
      "type": "text",
      "x": 242.43327867936028,
      "y": -8687.95499988883,
      "width": 478.939697265625,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "b1L",
      "roundness": null,
      "seed": 2095532259,
      "version": 162,
      "versionNonce": 331430019,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763993156183,
      "link": null,
      "locked": false,
      "text": "An index on views, we will have sorted list wrt\nvideoId. Take views, find the videos of topk and\nreturn it. Easy pisy:O(k)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "An index on views, we will have sorted list wrt\nvideoId. Take views, find the videos of topk and\nreturn it. Easy pisy:O(k)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "vUMfnhb3CpePuzLKkeJmB",
      "type": "text",
      "x": -579.842485152893,
      "y": -8610.353657385602,
      "width": 589.1996459960938,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "b1M",
      "roundness": null,
      "seed": 1128514403,
      "version": 143,
      "versionNonce": 1451454797,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763993297380,
      "link": null,
      "locked": false,
      "text": "Notes:\n1. simple O(1) append in sql but in the index it will be O(logn)\n2. get api is also running now. \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Notes:\n1. simple O(1) append in sql but in the index it will be O(logn)\n2. get api is also running now. \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
