      "seed": 1166393704,
      "version": 232,
      "versionNonce": 1255638632,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772859746917,
      "link": null,
      "locked": false,
      "text": "[The first approach is if I store the topk:{window}:{truncated_timestamp} \nin cache, then some read requests are going to be only beyond 10ms. Others will be real \nfast. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "[The first approach is if I store the topk:{window}:{truncated_timestamp} \nin cache, then some read requests are going to be only beyond 10ms. Others will be real \nfast. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
