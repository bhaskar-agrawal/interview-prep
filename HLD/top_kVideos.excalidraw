      "link": null,
      "locked": false,
      "text": "[talk about the problem of massive write, write latency on index\nand only able to support all time videos.]",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "[talk about the problem of massive write, write latency on index\nand only able to support all time videos.]",
      "autoResize": true,
