    },
    {
      "id": "WuFnKbcv7-vVhmaIl-C0F",
      "type": "text",
      "x": 275.27617917935663,
      "y": -8403.768321007763,
      "width": 498.65972900390625,
      "height": 75,
      "angle": 0,
