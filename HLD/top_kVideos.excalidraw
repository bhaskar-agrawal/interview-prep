      "isDeleted": false,
      "boundElements": null,
      "updated": 1772859427705,
      "link": null,
      "locked": false,
      "text": "[for arbitrary window, the scan is to be done\nfor all the rows in DB. This is the real bottleneck \nshared to the interviewer.]",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "[for arbitrary window, the scan is to be done\nfor all the rows in DB. This is the real bottleneck \nshared to the interviewer.]",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "a9iND6AfdV95gMqSQWRXX",
      "type": "text",
      "x": 257.6790651060627,
      "y": -8080.735584090915,
      "width": 859.5194702148438,
      "height": 75,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
