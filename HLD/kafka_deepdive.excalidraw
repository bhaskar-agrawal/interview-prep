      "link": null,
      "locked": false,
      "text": "Kafka deep dive\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Kafka deep dive\n\n\n",
