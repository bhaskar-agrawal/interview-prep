      "updated": 1773030138114,
      "link": null,
      "locked": false,
      "text": "LC may decide that they only scale the user onboarding service but not the code processing service, that's where the queues might be used\nfor loose coupling.\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "LC may decide that they only scale the user onboarding service but not the code processing service, that's where the queues might be used\nfor loose coupling.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
