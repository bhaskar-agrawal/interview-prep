    },
    {
      "id": "19jvHl9qPg3nqH9ZupKGS",
      "type": "text",
      "x": -2301.3137934202728,
      "y": -13208.906727790069,
      "width": 811.9393920898438,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 1943056692,
      "version": 738,
      "versionNonce": 1242585484,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1757395050050,
      "link": null,
      "locked": false,
      "text": "1. Brokers: responsible for handling queues. \n     - can have multiple partitions. Partition is mostly on physical data segregation.\n2. Topic: logical groupin of partition on basis of data \n3. producer/consumer:\n\nUnder the hood on kafka side: message/records are same. \n   Each message contains: ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Brokers: responsible for handling queues. \n     - can have multiple partitions. Partition is mostly on physical data segregation.\n2. Topic: logical groupin of partition on basis of data \n3. producer/consumer:\n\nUnder the hood on kafka side: message/records are same. \n   Each message contains: ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LEuClyhHKUDQW58eSahAP",
      "type": "text",
      "x": -2276.498955229531,
      "y": -13520.812272516592,
      "width": 1036.859375,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a8",
      "roundness": null,
      "seed": 459575860,
      "version": 594,
      "versionNonce": 316122036,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1757394953218,
      "link": null,
      "locked": false,
      "text": "Example:\nreal time events updates in case of football game. \n  producer -> queue -> consumer. \nTeams increase: then #queues increase to have same effect. \n\nToo many events: # consumer inc/. So consumer group one consumer processed the event then it is fine.\n\nLet's say more games onboarded: soccer, basketball\nMultiple topics one topic for each game. Each topic can be used by set of consumers or consumer groups. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Example:\nreal time events updates in case of football game. \n  producer -> queue -> consumer. \nTeams increase: then #queues increase to have same effect. \n\nToo many events: # consumer inc/. So consumer group one consumer processed the event then it is fine.\n\nLet's say more games onboarded: soccer, basketball\nMultiple topics one topic for each game. Each topic can be used by set of consumers or consumer groups. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
