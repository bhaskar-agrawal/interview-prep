      "boundElements": null,
      "updated": 1773030941238,
      "link": null,
      "locked": false,
      "text": "The keys are assigned on the basis of #partitions and modulo of key.\nOffset is unique inside a single partition instead of single topic.  ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
