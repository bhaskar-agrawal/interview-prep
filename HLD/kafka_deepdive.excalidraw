    {
      "id": "CPCN1SHP3BCpnNeoUm93L",
      "type": "text",
      "x": -2281.5888607082898,
      "y": -12737.881107338568,
      "width": 1157.5391845703125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "aG",
      "roundness": null,
      "seed": 155222668,
      "version": 424,
      "versionNonce": 1731239354,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1763817169147,
      "link": null,
      "locked": false,
      "text": "The value in braces is offset. This is maintained by consumer when they process, in case of consumer failure they can \nfind the last consumed offset to find the right message to consume to. The value is stored in kafka btw. \n\n-> Kafka has robust availability via replication. \n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The value in braces is offset. This is maintained by consumer when they process, in case of consumer failure they can \nfind the last consumed offset to find the right message to consume to. The value is stored in kafka btw. \n\n-> Kafka has robust availability via replication. \n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
