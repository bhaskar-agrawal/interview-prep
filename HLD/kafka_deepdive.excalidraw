      "seed": 1564908340,
      "version": 228,
      "versionNonce": 289455500,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1757395090206,
      "link": null,
      "locked": false,
      "text": "This message when pushed its pushed to specific partition\nusing partition key. Then that partition broker mapping is fetched\nfrom some hash map, to get the right broker to push the message to.\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This message when pushed its pushed to specific partition\nusing partition key. Then that partition broker mapping is fetched\nfrom some hash map, to get the right broker to push the message to.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
