      "index": "a1",
      "roundness": null,
      "seed": 802033316,
      "version": 386,
      "versionNonce": 1031424706,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773729203498,
      "link": null,
      "locked": false,
      "text": "functional:\n1. given a big url -> short url\n2. (chars allowed can be checked) for now (a-z, A-Z, 0-9)\n3. shortened url can not be updated or deleted. \n4. redirect in case of short url sent. \n\nassumptions:\n1. shortened url can not be updated or deleted\n2. redirect in case of short url sent. ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "functional:\n1. given a big url -> short url\n2. (chars allowed can be checked) for now (a-z, A-Z, 0-9)\n3. shortened url can not be updated or deleted. \n4. redirect in case of short url sent. \n\nassumptions:\n1. shortened url can not be updated or deleted\n2. redirect in case of short url sent. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "EnbwuvGPI0cHznwH8kPWR",
      "type": "text",
      "x": -1506.0674730790734,
      "y": -14000.11658459844,
      "width": 365.95953369140625,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 659405604,
      "version": 357,
      "versionNonce": 641088094,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773729203498,
      "link": null,
      "locked": false,
      "text": "non- functional:\n1. latency low, 100ms\n2. scale: 10k qps\n3. secure system. Alerting and \nmonitoring.\n4. highly available. \n5. idempotent system.\n6. avg url length: 100 chars. \n7. scale to 1B short urls and 100 M DAU\n\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "non- functional:\n1. latency low, 100ms\n2. scale: 10k qps\n3. secure system. Alerting and \nmonitoring.\n4. highly available. \n5. idempotent system.\n6. avg url length: 100 chars. \n7. scale to 1B short urls and 100 M DAU\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LEqxh1OWMpy3V4qqUleX6",
      "type": "text",
      "x": -2225.705718006086,
      "y": -13677.887302255138,
      "width": 292.3395690917969,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "a3",
      "roundness": null,
      "seed": 647706780,
      "version": 435,
      "versionNonce": 724017794,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1773729203498,
      "link": null,
      "locked": false,
      "text": "APIs:\n\n1. PUT/POST api/v1/url\n{\n  url: big_url\n}\n201- status code\n{\nshortUrl: \nbigUrl: \n}\n\n2. GET api/v1/url?shortUrl={}\n302: temporary redirect. \n\nHigh level design:\n\n1. Get a big url -> get a short url\n\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "APIs:\n\n1. PUT/POST api/v1/url\n{\n  url: big_url\n}\n201- status code\n{\nshortUrl: \nbigUrl: \n}\n\n2. GET api/v1/url?shortUrl={}\n302: temporary redirect. \n\nHigh level design:\n\n1. Get a big url -> get a short url\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
