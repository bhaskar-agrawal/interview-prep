    {
      "id": "jLtMYQkW7hhlUxIkjux2k",
      "type": "text",
      "x": -2223.3946290130843,
      "y": -13995.36477105964,
      "width": 512.0193481445312,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
