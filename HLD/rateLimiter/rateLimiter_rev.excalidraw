      "text": "hash collisions issue: use of hash function. Adding nonce if same hash is getting generated. This solution is not robust.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "hash collisions issue: use of hash function. Adding nonce if same hash is getting generated. This solution is not robust.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "pBjaJ35L5TK3BOzBx5m28",
      "type": "text",
      "x": -2419.0817310587972,
      "y": -11704.337997402004,
      "width": 1351.89794921875,
      "height": 425,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
