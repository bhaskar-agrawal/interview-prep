    {
      "id": "wZdX7sgRv_jeR8xyQcz4L",
      "type": "text",
      "x": 809.3120504824894,
      "y": -14003.033808491782,
      "width": 145.43984985351562,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
