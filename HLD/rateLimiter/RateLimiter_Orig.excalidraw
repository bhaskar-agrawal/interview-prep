      "isDeleted": false,
      "boundElements": [],
      "updated": 1770471096673,
      "link": null,
      "locked": false,
      "text": "Client: depends on the type of api and the users of my system. If developer api then api key is fine\nand if user then userName coming from jwt token of auth header is fine.\nThe IP is also used sometimes coming from X-Forwarded-For header. Authorization header for user id and\nX-API-key for developer api.\nA combination is needed, like that users are allowed upto some limit, specific ip limits and then total api limit\ndepending on system limits.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Client: depends on the type of api and the users of my system. If developer api then api key is fine\nand if user then userName coming from jwt token of auth header is fine.\nThe IP is also used sometimes coming from X-Forwarded-For header. Authorization header for user id and\nX-API-key for developer api.\nA combination is needed, like that users are allowed upto some limit, specific ip limits and then total api limit\ndepending on system limits.",
      "autoResize": true,
      "lineHeight": 1.25
    },
