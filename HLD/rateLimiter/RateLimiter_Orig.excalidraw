    {
      "id": "3fctCqijPY_MkEByEUWiG",
      "type": "text",
      "x": 160.66659803833005,
      "y": -11295.726698122135,
      "width": 462.1115417480469,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
