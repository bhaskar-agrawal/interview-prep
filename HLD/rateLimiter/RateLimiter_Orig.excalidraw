      "seed": 1324156002,
      "version": 444,
      "versionNonce": 211977342,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765254086494,
      "link": null,
      "locked": false,
      "text": "Best approach as all the clients are throttled before\nmaking a request to service.\nAll the info is taken from request itself \nlike: userId, headers and jwt.\nThe complex logic like that premium users is allowed\nto make requests, those are handled only using\njwt token information.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Best approach as all the clients are throttled before\nmaking a request to service.\nAll the info is taken from request itself \nlike: userId, headers and jwt.\nThe complex logic like that premium users is allowed\nto make requests, those are handled only using\njwt token information.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "n4not6o8wzbHekXAp8EFP",
