      "seed": 1627933246,
      "version": 34,
      "versionNonce": 852548222,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765252715826,
      "link": null,
      "locked": false,
      "text": "Rate limiter design\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Rate limiter design\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "n_-Rw91w3O1kC-YhhXcxF",
      "type": "text",
      "x": 536.8576518618468,
      "y": -13939.98944189644,
      "width": 770.25537109375,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "b9l",
      "roundness": null,
      "seed": 1408585058,
      "version": 76,
      "versionNonce": 542023330,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765252939909,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- identify users by id, ip, or api key\n- limit requests based on configurable rules\n- return proper error headers and status codes\n\nNon-functional Requirements\n- low latency check (< 10ms)- this should be less only. As we don't want system to be heavy here. \n- availability >> consistency\n- scale to 1M rps",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- identify users by id, ip, or api key\n- limit requests based on configurable rules\n- return proper error headers and status codes\n\nNon-functional Requirements\n- low latency check (< 10ms)- this should be less only. As we don't want system to be heavy here. \n- availability >> consistency\n- scale to 1M rps",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "S29uihoXrZuiDnLwQilGQ",
      "type": "text",
      "x": 341.0082452077747,
      "y": -13710.90926949238,
      "width": 617.0074462890625,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 90,
      "groupIds": [],
      "frameId": null,
      "index": "b9m",
      "roundness": null,
      "seed": 1955645922,
      "version": 244,
      "versionNonce": 948109602,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1765253105286,
      "link": null,
      "locked": false,
      "text": "Core entities:\n\n1. Rules: rules on the ip, userId\n2. clients: entities being rate limited, could be users. \n3. requests: the real request which contains client info, endpoints and headers.\n\nSystem interface:\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n\n1. Rules: rules on the ip, userId\n2. clients: entities being rate limited, could be users. \n3. requests: the real request which contains client info, endpoints and headers.\n\nSystem interface:\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
