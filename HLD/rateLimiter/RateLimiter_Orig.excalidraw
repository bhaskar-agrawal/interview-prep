    {
      "id": "WdccOnXbpntgmn52jYcAm",
      "type": "text",
      "x": 1147.7381116059546,
      "y": -13018.71948929612,
      "width": 417.03955078125,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
